{
  "$schema": "https://raw.githubusercontent.com/microsoft/vcpkg-tool/main/docs/vcpkg.schema.json",
  "name": "engine",
  "version": "0.1.0",
  "description": "C++ Game Engine",
  "dependencies": [
    "glm",
    "nlohmann-json",
    "stb",
    "cgltf",
    "miniaudio",
    "drlibs",
    "tinyobjloader",
    {
      "name": "joltphysics",
      "version>=": "5.0.0"
    },
    {
      "name": "entt",
      "version>=": "3.12.0"
    }
  ],
  "features": {
    "tests": {
      "description": "Build unit tests",
      "dependencies": [
        {
          "name": "catch2",
          "platform": "!uwp"
        }
      ]
    }
  }
}
