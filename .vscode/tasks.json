{
	"version": "2.0.0",
	"tasks": [
		{
			"label": "Configure",
			"type": "shell",
			"command": "cmake",
			"args": ["--preset", "Linux-Debug"],
			"options": { "cwd": "${workspaceFolder}" },
			"problemMatcher": [],
			"detail": "Run CMake configure (Linux-Debug)"
		},
		{
			"label": "Build: Debug",
			"type": "shell",
			"command": "cmake",
			"args": ["--build", "--preset", "Linux-Debug"],
			"group": {
				"kind": "build",
				"isDefault": true
			},
			"problemMatcher": "$gcc",
			"detail": "Build all targets (Debug)"
		},
		{
			"label": "Build: Dev",
			"type": "shell",
			"command": "cmake",
			"args": ["--build", "--preset", "Linux-Dev"],
			"group": "build",
			"problemMatcher": "$gcc",
			"detail": "Build all targets (Dev + tests)"
		},
		{
			"label": "Rebuild: Debug",
			"type": "shell",
			"command": "cmake",
			"args": ["--build", "--preset", "Linux-Debug", "--clean-first"],
			"group": "build",
			"problemMatcher": "$gcc",
			"detail": "Clean and rebuild all targets (Debug)"
		}
	]
}
